# ── TunnelBridge Environment ──────────────────────────────────

# امنیت
SECRET_KEY=replace-with-random-64-char-string

# نقش این سرور: iran (ورودی) یا foreign (خروجی)
SERVER_ROLE=iran

# آدرس سرور خارج (فقط برای سرور ایران لازم است)
FOREIGN_SERVER_IP=1.2.3.4
FOREIGN_SERVER_PORT=443

# لاگ
LOG_LEVEL=INFO

# مسیر باینری‌ها (در صورت نیاز تغییر دهید)
XRAY_BIN=/usr/local/bin/xray
GOST_BIN=/usr/local/bin/gost
RATHOLE_BIN=/usr/local/bin/rathole
HYSTERIA2_BIN=/usr/local/bin/hysteria2
OPENVPN_BIN=/usr/sbin/openvpn
